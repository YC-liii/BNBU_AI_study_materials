<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>数据结构与算法</title>
  </head>
  <body>
    <outline text="一、课程总览" _note="核心目标：从程序员到架构师，掌握数据结构与算法联动逻辑">
      <outline text="1. 课程目标" _note="1. 学会问题分析与解决方案设计；2. 具备独立编码实现能力；3. 理解数据结构与算法的应用场景"/>
      <outline text="2. 基础信息" _note="教材：《DATA STRUCTURES AND ALGORITHM ANALYSIS IN JAVA》（MARK ALLEN WEISS）">
        <outline text="先修要求" _note="1. Java编程（Eclipse、伪代码转代码）；2. 基础数学（递归方程、符号运算）；3. 计算机体系结构（存储、内存访问）"/>
        <outline text="评分规则" _note="书面作业15%+编程作业35%+课堂练习10%+期末考试40%；无迟交，抄袭零分"/>
      </outline>
    </outline>
    <outline text="二、基础预备知识">
      <outline text="1. Java核心复习">
        <outline text="循环结构" _note="for（已知次数）、while（条件终止）、do-while（至少执行1次）"/>
        <outline text="引用机制" _note="对象通过引用访问，赋值共享对象，无直接拷贝"/>
        <outline text="递归核心" _note="必须有终止条件，避免死循环；函数自调用"/>
      </outline>
      <outline text="2. 递归实战习题" _note="要求：独立编码，含main函数与递归函数">
        <outline text="阶乘计算" _note="类名T1，函数int factR(int n)；base: factR(1)=1"/>
        <outline text="最大公约数（GCD）" _note="类名T2，函数int GCD(int x,int y)；公式：GCD(x,y)=GCD(y,x%y)"/>
        <outline text="回文判断" _note="类名T3，函数boolean palindrome(String s)；case敏感"/>
        <outline text="二进制转换" _note="可选，类名T4，函数String binary(int n)；例：binary(27)=110011"/>
      </outline>
    </outline>
    <outline text="三、算法分析基础">
      <outline text="1. 算法核心概念" _note="定义：解决问题的明确指令集合（输入→处理→输出）">
        <outline text="描述方式" _note="自然语言、伪代码、程序代码"/>
      </outline>
      <outline text="2. 复杂度分析">
        <outline text="评估维度" _note="时间复杂度（操作次数）、空间复杂度（内存占用）"/>
        <outline text="分析场景" _note="最坏情况（最长执行时间）、最好情况（最短）、平均情况"/>
        <outline text="复杂度表示" _note="大O（上界）、Omega（下界）、Theta（紧界）">
          <outline text="大O规则" _note="忽略低阶项与系数；例：5n³+4n²→O(n³)"/>
        </outline>
        <outline text="计算规则" _note="1. 循环：次数×内部语句复杂度；2. 嵌套：层数乘积；3. 递归：递推关系求解"/>
      </outline>
      <outline text="3. 常见复杂度等级" _note="从快到慢：O(1)→O(logn)→O(n)→O(nlogn)→O(n²)→O(2ⁿ)→O(n!)"/>
    </outline>
    <outline text="四、线性数据结构">
      <outline text="1. 抽象数据类型（ADT）" _note="封装数据与操作，隐藏实现细节">
        <outline text="核心优势" _note="模块化、可复用、信息隐藏、并行开发、快速原型"/>
        <outline text="列表ADT" _note="操作：makeEmpty、insert、remove、find、findKth、printList"/>
      </outline>
      <outline text="2. 链表">
        <outline text="实现方式" _note="节点（data+next引用）+ 头指针；非连续存储"/>
        <outline text="核心操作" _note="插入（头部/中间/尾部）、删除（指定元素）、查找（指定元素）"/>
        <outline text="数组vs链表对比" _note="数组：随机访问O(1)，插入删除O(n)；链表：随机访问O(n)，插入删除O(1)"/>
      </outline>
      <outline text="3. 栈">
        <outline text="核心性质" _note="LIFO（后进先出），仅栈顶操作"/>
        <outline text="实现方式" _note="数组（固定容量）、链表（动态容量）"/>
        <outline text="核心操作" _note="push（入栈）、pop（出栈）、top（栈顶元素）、isEmpty/isFull"/>
        <outline text="应用场景" _note="表达式求值、回溯、内存管理"/>
      </outline>
      <outline text="4. 队列">
        <outline text="核心性质" _note="FIFO（先进先出），队尾入、队首出"/>
        <outline text="实现方式" _note="循环数组（解决“假满”）、链表"/>
        <outline text="核心操作" _note="enqueue（入队）、dequeue（出队）、isEmpty/isFull"/>
        <outline text="应用场景" _note="打印机队列、Web爬虫、系统缓冲区"/>
      </outline>
    </outline>
    <outline text="五、排序算法">
      <outline text="1. 插入排序" _note="核心：前p个有序，插入第p+1个元素">
        <outline text="复杂度" _note="最好O(n)、最坏O(n²)、平均O(n²)"/>
      </outline>
      <outline text="2. 归并排序（分治）" _note="步骤：拆分→递归排序→合并">
        <outline text="拆分" _note="数组：center=(left+right)/2；链表：扫描至⌊N/2⌋"/>
        <outline text="合并" _note="用额外数组B，合并两个有序子数组"/>
        <outline text="复杂度" _note="最坏/最好/平均均为O(nlogn)（稳定）"/>
      </outline>
      <outline text="3. 快速排序（分治）" _note="实际效率最高，不稳定">
        <outline text="核心步骤" _note="选pivot→分区→递归排序左右"/>
        <outline text="优化策略" _note="1. pivot（三数取中）；2. 小数组用插入排序（长度≤10）"/>
        <outline text="复杂度" _note="平均O(nlogn)、最坏O(n²)（极少出现）"/>
      </outline>
      <outline text="4. 堆排序" _note="基于二叉堆（近似完全二叉树）">
        <outline text="二叉堆性质" _note="最小堆：父节点≤子节点；最大堆：父节点≥子节点"/>
        <outline text="核心步骤" _note="构建堆→删除堆顶→调整堆"/>
        <outline text="复杂度" _note="O(nlogn)（不稳定）"/>
        <outline text="关联：优先级队列" _note="操作：insert(O(logn))、deleteMin(O(logn))"/>
      </outline>
    </outline>
    <outline text="六、树形数据结构">
      <outline text="1. 二叉树基础">
        <outline text="核心术语" _note="根、叶、子节点、父节点、路径、深度、高度"/>
        <outline text="遍历方式" _note="前序（根→左→右）、中序（左→根→右）、后序（左→右→根）"/>
      </outline>
      <outline text="2. 二叉搜索树（BST）" _note="性质：左子树＜根＜右子树（无重复）">
        <outline text="核心操作" _note="查找O(h)、插入O(h)、删除O(h)（h为树高）">
          <outline text="删除分类" _note="1. 叶节点：直接删；2. 单孩子：父节点绕过；3. 双孩子：替换为右子树最小节点"/>
        </outline>
        <outline text="局限" _note="最坏h=n（退化为链表），效率O(n)"/>
      </outline>
      <outline text="3. AVL树（平衡BST）" _note="平衡性质：每个节点左右子树高度差≤1">
        <outline text="平衡维护" _note="插入/删除后回溯，失衡节点旋转">
          <outline text="单旋转" _note="左左（右旋转）、右右（左旋转）"/>
          <outline text="双旋转" _note="左右（左转子→右转父）、右左（右转子→左转父）"/>
        </outline>
        <outline text="复杂度" _note="所有操作O(logn)（h=O(logn)）"/>
      </outline>
      <outline text="4. B+树（M阶）" _note="适合磁盘存储，减少I/O次数">
        <outline text="结构性质" _note="1. 数据仅存叶节点；2. 内部节点存索引；3. 叶节点有序链接">
          <outline text="节点要求" _note="根：2~M子节点；非根内部：⌈M/2⌉~M子节点；叶：⌈L/2⌉~L数据项"/>
        </outline>
        <outline text="核心操作" _note="插入：满则分裂；删除：不足则合并/借元素"/>
        <outline text="应用场景" _note="数据库索引"/>
      </outline>
    </outline>
    <outline text="七、图结构与搜索">
      <outline text="1. 图的基础">
        <outline text="定义" _note="G=(V,E)；V顶点集，E边集（无向/有向）"/>
        <outline text="表示方式" _note="邻接矩阵（稠密图，O(n²)）、邻接表（稀疏图，O(n+m)）"/>
        <outline text="核心术语" _note="路径、简单路径、循环、连通分量"/>
      </outline>
      <outline text="2. 广度优先搜索（BFS）" _note="FIFO队列实现，逐层访问">
        <outline text="核心功能" _note="1. 查找可达顶点；2. 无加权图最短路径（边数最少）"/>
        <outline text="扩展功能" _note="pred数组（记录前驱，重建路径）、d数组（记录距离）"/>
        <outline text="复杂度" _note="邻接表O(n+m)、邻接矩阵O(n²)"/>
      </outline>
    </outline>
  </body>
</opml>